# ---- Writtly backend production env (copy to .env on the EC2) ----
ENVIRONMENT=production
DEBUG=false
CREATE_TABLES_ON_STARTUP=true

# Long random string: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_STRING

# RDS PostgreSQL (async driver). Get host from the RDS console.
DATABASE_URL=postgresql+asyncpg://writtly:REPLACE_DB_PASSWORD@your-db.abcdefg.ap-south-1.rds.amazonaws.com:5432/writtly

# Frontend origins allowed to call the API (comma-separated, no trailing slash)
CORS_ORIGINS=https://writtly.in,https://www.writtly.in

# Twilio (use your rotated credentials)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
SMS_ENABLED=true
SMS_DEFAULT_COUNTRY_CODE=+91

# ---- Receipts & logos (S3) ----
S3_BUCKET=writtly-assets
S3_REGION=ap-south-1
# Base URL used to build short receipt links (must be your API domain)
PUBLIC_BASE_URL=https://api.writtly.in
