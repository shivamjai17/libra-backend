# Copy to .env and fill in. NEVER commit real secrets.
SECRET_KEY=change-me-to-a-long-random-string

# Twilio SMS — get these from https://console.twilio.com
# (rotate any credentials that were ever shared in chat/code)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
SMS_ENABLED=true
SMS_DEFAULT_COUNTRY_CODE=+91
